# Copy to android/key.properties and fill in real values.
# NEVER commit the real key.properties or the .jks keystore.
#
# Create the upload keystore once with:
#   keytool -genkey -v -keystore ~/mytokens-upload.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# storeFile may be absolute or relative to the android/ directory.

storePassword=CHANGE_ME
keyPassword=CHANGE_ME
keyAlias=upload
storeFile=/absolute/path/to/mytokens-upload.jks
